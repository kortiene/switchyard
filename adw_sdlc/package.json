{
  "name": "adw-sdlc",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "TypeScript control plane for the phased ADW pipeline: one AgentRunner seam, four interchangeable runner backends (claude/codex/opencode/pi). See PLAN.md.",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint:env": "bash ../scripts/check-adw-sdlc-env.sh",
    "verify": "npm run typecheck && npm run lint:env && npm run pack:check && npm run mirror:check && npm run wiki:check && npm run coverage && npm run build && rm -rf dist",
    "issue": "tsx src/cli.ts",
    "pack:generate": "tsx tools/pack-generate.ts",
    "pack:check": "tsx tools/pack-generate.ts --check",
    "mirror:check": "tsx tools/mirror-check.ts --check",
    "mirror:sync": "tsx tools/mirror-check.ts --write",
    "wiki:check": "tsx tools/wiki-validate.ts --check",
    "parity:rate": "tsx tools/parity-rate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@openai/codex-sdk": "0.139.0",
    "@opencode-ai/sdk": "^1.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
