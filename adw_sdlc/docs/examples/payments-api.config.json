{
  "version": 1,
  "project": {
    "id": "payments-api",
    "name": "Acme Payments API"
  },
  "prompts": {
    "defaultRoot": ".adw/prompts",
    "runnerRoots": {}
  },
  "phases": [
    "classify",
    "plan",
    "implement",
    "tests",
    "resolve",
    "e2e",
    "review",
    "patch",
    "document"
  ],
  "providers": {
    "cli": { "type": "github" },
    "workItems": {
      "type": "github",
      "closedStates": ["CLOSED"],
      "inProgressStatus": "In Progress",
      "doneStatus": "Done",
      "statusFieldName": "Status"
    },
    "vcs": { "type": "git" },
    "changeRequests": { "type": "github" }
  },
  "progress": {
    "tag": "[ACME-ADW]"
  },
  "branching": {
    "defaultPrefix": "feat",
    "labelPrefixes": {
      "bug": "fix",
      "security": "fix",
      "migration": "chore",
      "docs": "docs"
    },
    "slug": {
      "maxLength": 48,
      "stripDiacritics": true,
      "stripPhaseIssuePrefix": false
    }
  },
  "gates": {
    "e2e": {
      "hints": [
        "stripe",
        "webhook",
        "payment",
        "refund",
        "migration",
        "checkout",
        "public api"
      ]
    },
    "documentation": {
      "hints": [
        "public api",
        "config",
        "endpoint",
        "migration"
      ],
      "exactFiles": ["README.md", "CHANGELOG.md"],
      "pathPrefixes": ["docs/"],
      "fileExtensions": [".md"]
    }
  },
  "models": {
    "classifyModel": "claude-haiku-4-5",
    "defaultTier": "mid",
    "phaseTiers": {
      "classify": "cheap",
      "plan": "capable",
      "implement": "capable",
      "tests": "mid",
      "resolve": "mid",
      "e2e": "mid",
      "review": "capable",
      "patch": "capable",
      "document": "mid"
    },
    "tiers": {
      "cheap": {
        "claude": "claude-haiku-4-5",
        "pi": "haiku",
        "codex": "gpt-5.4-mini",
        "opencode": "anthropic/claude-haiku-4-5"
      },
      "mid": {
        "claude": "claude-sonnet-4-6",
        "pi": "sonnet",
        "codex": "gpt-5.4",
        "opencode": "anthropic/claude-sonnet-4-6"
      },
      "capable": {
        "claude": "claude-opus-4-8",
        "pi": "opus",
        "codex": "gpt-5.5",
        "opencode": "anthropic/claude-opus-4-8"
      }
    }
  },
  "commands": {
    "defaultTestCommand": "npm test",
    "defaultFinalizeGates": ["npm run lint", "npm run typecheck", "npm run build"]
  }
}
